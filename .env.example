# ============================================================================
# FALIZ AI — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================================

# === CORE APP ===
APP_ENV=development
APP_VERSION=1.0.0
APP_NAME=FALIZ AI

# === SECURITY ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_random_64_char_hex_string_in_production
JWT_SECRET=change_me_to_random_64_char_hex_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# Encryption key for at-rest secrets (32 bytes base64)
ENCRYPTION_KEY=change_me_to_random_base64_32_bytes

# === DATABASE ===
# PostgreSQL
DATABASE_URL=postgresql+asyncpg://faliz:faliz_secure_password@localhost:5432/faliz
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# ChromaDB (Vector Store)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=faliz-memory

# === AI / LLM ===
# OpenAI (primary)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000

# Anthropic (fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === VOICE SERVICES ===
# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_monolingual_v1

# OpenAI Whisper (STT)
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=en

# Picovoice Porcupine (Wake Word Detection)
PICOVOICE_ACCESS_KEY=

# === GOOGLE SERVICES ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GMAIL_SCOPES=https://mail.google.com/
GOOGLE_MAPS_API_KEY=

# === EXTERNAL APIs ===
# Weather
OPENWEATHER_API_KEY=
OPENWEATHER_UNITS=metric

# News
NEWS_API_KEY=

# Wolfram Alpha
WOLFRAM_ALPHA_APP_ID=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=+1234567890

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/callback/spotify

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback/github

# === SMART HOME ===
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_VERIFY_SSL=true

# === SECURITY FEATURES ===
FACE_AUTH_ENABLED=true
FACE_AUTH_CONFIDENCE=0.8
FACE_AUTH_DETECTION_MODEL=retinaface

# === PLUGIN FEATURE FLAGS ===
PLUGIN_VOICE_ENABLED=true
PLUGIN_BRAIN_ENABLED=true
PLUGIN_CALENDAR_ENABLED=true
PLUGIN_TASKS_ENABLED=true
PLUGIN_COMMS_ENABLED=true
PLUGIN_INFO_ENABLED=true
PLUGIN_SYSTEM_ENABLED=true
PLUGIN_SMARTHOME_ENABLED=false
PLUGIN_VISION_ENABLED=true
PLUGIN_CREATE_ENABLED=true
PLUGIN_KNOWLEDGE_ENABLED=true
PLUGIN_CAREER_ENABLED=true
PLUGIN_ENTERTAINMENT_ENABLED=true
PLUGIN_LOCATION_ENABLED=true
PLUGIN_SECURITY_ENABLED=true
PLUGIN_ANALYTICS_ENABLED=true

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/faliz.log

# === CELERY (Background Tasks) ===
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TIMEZONE=UTC

# === API SETTINGS ===
API_VERSION=v1
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_PERIOD=60
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_CORS_CREDENTIALS=true

# === DEPLOYMENT ===
HOST=0.0.0.0
PORT=8000
WORKERS=4
SECURE_COOKIES=false  # Set to true in production

# === MONITORING ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# === BACKEND URL (for Electron) ===
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
